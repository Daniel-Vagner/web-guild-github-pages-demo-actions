@* <h2 class="mt-5">Upcoming Shows</h2>

@if (_shows is null)
{
    <p><em>Loading shows...</em></p>
}
else if (_shows.Length == 0)
{
    <p>No upcoming shows at the moment.</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Date</th>
                <th>Venue</th>
                <th>City</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var show in _shows)
            {
                <tr>
                    <td>@show.Date.ToString("dd MMM yyyy")</td>
                    <td>@show.Venue</td>
                    <td>@show.City</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Show[]? _shows;

    protected override async Task OnInitializedAsync()
    {
        _shows = await Http.GetFromJsonAsync<Show[]>("data/shows.json");
    }

    private sealed class Show
    {
        public DateOnly Date { get; set; }
        public string Venue { get; set; } = "";
        public string City { get; set; } = "";
    }
} *@
